{
  "name": "attestly",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:api": "wrangler dev --config apps/api/wrangler.jsonc",
    "dev:worker": "wrangler dev --config apps/worker/wrangler.jsonc",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev:evidence-api": "wrangler dev --config apps/evidence-api/wrangler.jsonc",
    "dev:ingestion": "wrangler dev --config apps/ingestion/wrangler.jsonc",
    "dev:evidence-console": "vite --config apps/evidence-console/vite.config.ts",
    "dev:extractor": "tsx apps/extractor/src/server.ts",
    "dev:questionnaire-api": "wrangler dev --config apps/questionnaire-api/wrangler.jsonc",
    "dev:questionnaire-worker": "wrangler dev --config apps/questionnaire-worker/wrangler.jsonc",
    "dev:questionnaire-console": "vite --config apps/questionnaire-console/vite.config.ts",
    "dev:questionnaire-processor": "tsx apps/questionnaire-processor/src/server.ts",
    "dev:answer-api": "wrangler dev --config apps/answer-api/wrangler.jsonc",
    "dev:generation-worker": "wrangler dev --config apps/generation-worker/wrangler.jsonc",
    "build": "npm run build:web && npm run build:api && npm run build:worker && npm run build:evidence-console && npm run build:evidence-api && npm run build:ingestion && npm run build:extractor && npm run build:questionnaire-console && npm run build:questionnaire-api && npm run build:questionnaire-worker && npm run build:questionnaire-processor && npm run build:answer-api && npm run build:generation-worker",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build:api": "wrangler deploy --dry-run --config apps/api/wrangler.jsonc --outdir dist/api",
    "build:worker": "wrangler deploy --dry-run --config apps/worker/wrangler.jsonc --outdir dist/worker",
    "build:evidence-console": "vite build --config apps/evidence-console/vite.config.ts",
    "build:evidence-api": "wrangler deploy --dry-run --config apps/evidence-api/wrangler.jsonc --outdir dist/evidence-api",
    "build:ingestion": "wrangler deploy --dry-run --config apps/ingestion/wrangler.jsonc --outdir dist/ingestion",
    "build:extractor": "tsc -p apps/extractor/tsconfig.json",
    "build:questionnaire-console": "vite build --config apps/questionnaire-console/vite.config.ts",
    "build:questionnaire-api": "wrangler deploy --dry-run --config apps/questionnaire-api/wrangler.jsonc --outdir dist/questionnaire-api",
    "build:questionnaire-worker": "wrangler deploy --dry-run --config apps/questionnaire-worker/wrangler.jsonc --outdir dist/questionnaire-worker",
    "build:questionnaire-processor": "tsc -p apps/questionnaire-processor/tsconfig.json",
    "build:answer-api": "wrangler deploy --dry-run --config apps/answer-api/wrangler.jsonc --outdir dist/answer-api",
    "build:generation-worker": "wrangler deploy --dry-run --config apps/generation-worker/wrangler.jsonc --outdir dist/generation-worker",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run typecheck && npm run test && npm run build",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:types": "supabase gen types typescript --local > packages/foundation/src/database.types.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@supabase/supabase-js": "^2.49.0",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.0.0",
    "hono": "^4.7.0",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "prettier": "^3.5.0",
    "supabase": "^2.20.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.5.0"
  }
}
